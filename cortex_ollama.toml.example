# cortex_ollama proxy configuration.
#
# Copy to one of (first found wins):
#   ./cortex_ollama.toml                          (project-local)
#   ~/.config/cortex-ollama/config.toml           (per-user)
# or set CORTEX_OLLAMA_CONFIG=/path/to/file.toml.
#
# Anything you don't set here uses the built-in defaults. Env vars still
# override the file (handy for one-shot experiments).

# ---------------------------------------------------------------------------
# Inference backend — which model server gets the agent traffic.
# Pick one: "ollama" (default), "openai" (or any OpenAI-compatible vendor),
# or "anthropic".
# ---------------------------------------------------------------------------
backend = "ollama"

[backends.ollama]
base_url = "http://127.0.0.1:11434"
model    = "qwen3.6:35b-a3b"

[backends.openai]
# Works with OpenAI itself and any /v1/chat/completions-compatible API
# (xAI Grok, Groq, OpenRouter, Together, vLLM, llama.cpp server, etc.).
# Tip: Ollama also serves an OpenAI-compat /v1 — handy for local testing
# of this backend without an API key:
#   base_url = "http://127.0.0.1:11434/v1"
#   api_key  = "ollama"
#   model    = "qwen3.6:35b-a3b"
base_url = "https://api.openai.com/v1"
api_key  = ""          # or set OPENAI_API_KEY in env
model    = "gpt-4o"

[backends.anthropic]
# Ollama does NOT serve /v1/messages natively. To test the Anthropic backend
# locally without a real API key, run LiteLLM as a translator:
#   pipx install 'litellm[proxy]'
#   litellm --model ollama_chat/qwen3.6:35b-a3b --port 14000
# then point this backend at it:
#   base_url = "http://127.0.0.1:14000"
#   api_key  = "anything"
#   model    = "ollama_chat/qwen3.6:35b-a3b"
base_url = "https://api.anthropic.com/v1"
api_key  = ""          # or set ANTHROPIC_API_KEY in env
model    = "claude-sonnet-4-5"
# Anthropic API version pin
api_version = "2023-06-01"

# ---------------------------------------------------------------------------
# Snowflake connection wiring (the credential blocks themselves still live in
# ~/.snowflake/config.toml — that's where the cortex CLI reads them).
# ---------------------------------------------------------------------------
[snowflake]
# Connection cortex authenticates with. This name also drives the TUI's
# "Agent Connection:" header line — change it to "llama-cpp", "lmstudio",
# "openrouter", or whatever matches what you're actually running. The
# wrapper auto-adds the matching [connections.<name>] block to
# ~/.snowflake/config.toml (pointed at our local stub).
agent_connection = "ollama"

# Connection used by the sql_execute tool. Empty = fully-local mode (SQL
# tools hit the stub and return no rows). Set to a real connection name
# from ~/.snowflake/config.toml to route SQL at a real account.
sql_connection = ""    # e.g. "streamgen", "sfse-na"

# ---------------------------------------------------------------------------
# Proxy listeners. Change if 2031/2443 collide with something else; if you
# move 2031, also export the new value as CORTEX_PROXY_HTTP_PORT so the
# wrapper's healthz check finds it.
# ---------------------------------------------------------------------------
[proxy]
http_port  = 2031
https_port = 2443
