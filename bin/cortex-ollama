#!/usr/bin/env bash
# Launch cortex (TUI or -p one-shot) with the local Ollama proxy.
#
# If the proxy is already listening on :2031, reuse it.
# Otherwise start it in the background, wait for it to be ready, launch
# cortex in the foreground, and tear the proxy down again on exit.
#
# Two modes, chosen by whether CORTEX_SQL_CONNECTION is set:
#   fully-local  (unset): agent and SQL both proxy-stubbed, no Snowflake contact.
#   hybrid       (set):   agent via proxy → Ollama, SQL tools → real Snowflake
#                         account named in CORTEX_SQL_CONNECTION.

set -uo pipefail

export CORTEX_AGENT_USE_LOCAL_ORCHESTRATOR=1
export NODE_TLS_REJECT_UNAUTHORIZED=0
export CORTEX_AGENT_CONNECTION="${CORTEX_AGENT_CONNECTION:-ollama}"

PROXY_HTTP_PORT="${CORTEX_PROXY_HTTP_PORT:-2031}"
REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CORTEX_BIN="${CORTEX_BIN:-$(command -v cortex 2>/dev/null || echo "$HOME/.local/bin/cortex")}"
OLLAMA_URL="${OLLAMA_BASE_URL:-http://127.0.0.1:11434}"

usage() {
  cat <<USAGE
Usage: cortex-ollama [--model NAME] [--list-models] [-- <cortex args>]

Options:
  --model, -M NAME    Use this Ollama model. If the proxy is already up,
                      hot-swaps via POST /model. Otherwise sets OLLAMA_MODEL
                      for the proxy we're about to start.
  --list-models       Print models available in Ollama and exit.
  --help, -h          Show this help.

Anything after -- (or unrecognised flags) is passed straight through to cortex.

Environment:
  OLLAMA_MODEL              Default model when starting the proxy.
  CORTEX_SQL_CONNECTION     Real Snowflake connection name (enables hybrid mode).
  CORTEX_AGENT_CONNECTION   Connection cortex uses for auth/agent (default: ollama).
USAGE
}

REQUESTED_MODEL=""
PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --model|-M) REQUESTED_MODEL="${2:-}"; shift 2 ;;
    --list-models)
      curl -sS "${OLLAMA_URL}/api/tags" \
        | python3 -c 'import sys,json; [print(m["name"]) for m in json.load(sys.stdin).get("models",[])]'
      exit 0 ;;
    --help|-h) usage; exit 0 ;;
    --) shift; PASSTHRU+=("$@"); break ;;
    *) PASSTHRU+=("$1"); shift ;;
  esac
done

if [[ ! -x "$CORTEX_BIN" ]]; then
  echo "cortex-ollama: cannot find the cortex binary. Set CORTEX_BIN." >&2
  exit 1
fi

healthz() { curl -sfo /dev/null --max-time 1 "http://127.0.0.1:${PROXY_HTTP_PORT}/healthz"; }

PROXY_PID=""
cleanup() {
  if [[ -n "$PROXY_PID" ]] && kill -0 "$PROXY_PID" 2>/dev/null; then
    echo
    echo "cortex-ollama: stopping proxy (pid $PROXY_PID)..."
    kill "$PROXY_PID" 2>/dev/null || true
    pkill -f "python -m proxy" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
}

if healthz; then
  echo "cortex-ollama: proxy already running on :${PROXY_HTTP_PORT} — reusing it."
  if [[ -n "$REQUESTED_MODEL" ]]; then
    RESP=$(curl -sS -X POST -H 'Content-Type: application/json' \
      -d "{\"model\":\"${REQUESTED_MODEL}\"}" \
      "http://127.0.0.1:${PROXY_HTTP_PORT}/model")
    if echo "$RESP" | grep -q '"ok": true\|"ok":true'; then
      echo "cortex-ollama: model swapped → ${REQUESTED_MODEL}"
    else
      echo "cortex-ollama: model swap FAILED:" >&2
      echo "$RESP" >&2
      exit 1
    fi
  fi
else
  if [[ -n "$REQUESTED_MODEL" ]]; then
    export OLLAMA_MODEL="$REQUESTED_MODEL"
    echo "cortex-ollama: starting proxy with OLLAMA_MODEL=${REQUESTED_MODEL}..."
  else
    echo "cortex-ollama: starting proxy..."
  fi
  ( cd "$REPO_DIR" && exec pixi run serve >/tmp/cortex-ollama-proxy.log 2>&1 ) &
  PROXY_PID=$!
  trap cleanup EXIT INT TERM HUP

  for i in $(seq 1 30); do
    if healthz; then
      echo "cortex-ollama: proxy ready (pid $PROXY_PID, log /tmp/cortex-ollama-proxy.log)"
      break
    fi
    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      echo "cortex-ollama: proxy exited before becoming ready. See /tmp/cortex-ollama-proxy.log" >&2
      tail -30 /tmp/cortex-ollama-proxy.log >&2 || true
      exit 1
    fi
    sleep 1
  done
  if ! healthz; then
    echo "cortex-ollama: proxy did not become ready within 30s. See /tmp/cortex-ollama-proxy.log" >&2
    tail -30 /tmp/cortex-ollama-proxy.log >&2 || true
    exit 1
  fi
fi

ACTIVE_MODEL=$(curl -sS "http://127.0.0.1:${PROXY_HTTP_PORT}/healthz" \
  | python3 -c 'import sys,json; print(json.load(sys.stdin).get("model",""))' 2>/dev/null)

if [[ -n "${CORTEX_SQL_CONNECTION:-}" ]]; then
  echo "cortex-ollama: hybrid mode — agent=${CORTEX_AGENT_CONNECTION}, sql=${CORTEX_SQL_CONNECTION}, model=${ACTIVE_MODEL}"
else
  echo "cortex-ollama: fully-local mode — model=${ACTIVE_MODEL}"
fi

if [[ -z "$PROXY_PID" ]]; then
  exec "$CORTEX_BIN" -c "$CORTEX_AGENT_CONNECTION" --no-auto-update ${PASSTHRU[@]+"${PASSTHRU[@]}"}
else
  "$CORTEX_BIN" -c "$CORTEX_AGENT_CONNECTION" --no-auto-update ${PASSTHRU[@]+"${PASSTHRU[@]}"}
fi
