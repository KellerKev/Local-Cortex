#!/usr/bin/env bash
# Launch cortex (TUI or -p one-shot) with the local Ollama proxy.
#
# If the proxy is already listening on :2031, reuse it.
# Otherwise start it in the background, wait for it to be ready, launch
# cortex in the foreground, and tear the proxy down again on exit.
#
# Two modes, chosen by whether CORTEX_SQL_CONNECTION is set:
#   fully-local  (unset): agent and SQL both proxy-stubbed, no Snowflake contact.
#   hybrid       (set):   agent via proxy → Ollama, SQL tools → real Snowflake
#                         account named in CORTEX_SQL_CONNECTION.

set -uo pipefail

export CORTEX_AGENT_USE_LOCAL_ORCHESTRATOR=1
export NODE_TLS_REJECT_UNAUTHORIZED=0

REPO_DIR="$(cd "$(dirname "$0")/.." && pwd)"
CORTEX_BIN="${CORTEX_BIN:-$(command -v cortex 2>/dev/null || echo "$HOME/.local/bin/cortex")}"

# Pull defaults out of cortex_ollama.toml (env vars still take precedence
# inside the proxy itself; this is just so the wrapper has the right port and
# Snowflake connection names without us re-implementing config layering).
read_config() {
  ( cd "$REPO_DIR" && python3 - <<'PY'
import sys, os
sys.path.insert(0, os.getcwd())
from proxy import config as c
cfg = c.load()
print("AGENT_CONNECTION=", cfg.agent_connection, sep="")
print("SQL_CONNECTION=", cfg.sql_connection, sep="")
print("HTTP_PORT=", cfg.http_port, sep="")
print("HTTPS_PORT=", cfg.https_port, sep="")
print("BACKEND=", cfg.backend.name, sep="")
print("BACKEND_URL=", cfg.backend.base_url, sep="")
print("BACKEND_MODEL=", cfg.backend.model, sep="")
PY
  )
}
eval "$(read_config | sed 's/^/_CFG_/')"

# Apply config; env var (if set) wins over config file.
export CORTEX_AGENT_CONNECTION="${CORTEX_AGENT_CONNECTION:-${_CFG_AGENT_CONNECTION:-ollama}}"
if [[ -z "${CORTEX_SQL_CONNECTION:-}" ]] && [[ -n "${_CFG_SQL_CONNECTION:-}" ]]; then
  export CORTEX_SQL_CONNECTION="${_CFG_SQL_CONNECTION}"
fi
PROXY_HTTP_PORT="${CORTEX_PROXY_HTTP_PORT:-${_CFG_HTTP_PORT:-2031}}"
OLLAMA_URL="${OLLAMA_BASE_URL:-${_CFG_BACKEND_URL:-http://127.0.0.1:11434}}"

usage() {
  cat <<USAGE
Usage: cortex-ollama [--list-models] [-h] [-- <cortex args>]

Pick a model with the OLLAMA_MODEL environment variable:

  OLLAMA_MODEL=qwen3.6:35b-a3b pixi run tui
  export OLLAMA_MODEL=qwen3.6:35b-a3b   # then run as normal

Mid-session swaps (without exiting cortex) are done from inside the TUI via
the bundled slash command \`/local-models\`, which prints the curl recipe.

Options:
  --list-models       Print models available in Ollama and exit.
  -h                  Show this help. (--help is forwarded to cortex.)

Environment:
  OLLAMA_MODEL              Model the proxy sends to Ollama (default: see proxy/server.py).
  CORTEX_SQL_CONNECTION     Real Snowflake connection name (enables hybrid mode).
  CORTEX_AGENT_CONNECTION   Connection cortex uses for auth/agent (default: ollama).
USAGE
}

list_ollama_models() {
  curl -sS --max-time 5 "${OLLAMA_URL}/api/tags" 2>/dev/null \
    | python3 -c 'import sys,json
try: ms = json.load(sys.stdin).get("models", [])
except Exception: ms = []
[print(m["name"]) for m in sorted(ms, key=lambda m: m["name"])]'
}

PASSTHRU=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    --list-models) list_ollama_models; exit 0 ;;
    -h) usage; exit 0 ;;  # short -h is ours; --help is forwarded to cortex
    *) PASSTHRU+=("$1"); shift ;;
  esac
done

if [[ ! -x "$CORTEX_BIN" ]]; then
  echo "cortex-ollama: cannot find the cortex binary. Set CORTEX_BIN." >&2
  exit 1
fi

healthz() { curl -sfo /dev/null --max-time 1 "http://127.0.0.1:${PROXY_HTTP_PORT}/healthz"; }

PROXY_PID=""
SETTINGS_FILE="$HOME/.snowflake/cortex/settings.json"
SETTINGS_BACKUP=""
cleanup() {
  if [[ -n "$PROXY_PID" ]] && kill -0 "$PROXY_PID" 2>/dev/null; then
    echo
    echo "cortex-ollama: stopping proxy (pid $PROXY_PID)..."
    kill "$PROXY_PID" 2>/dev/null || true
    pkill -f "python -m proxy" 2>/dev/null || true
    wait "$PROXY_PID" 2>/dev/null || true
  fi
  # Restore the user's persistent settings file
  if [[ -n "$SETTINGS_BACKUP" ]] && [[ -f "$SETTINGS_BACKUP" ]]; then
    mv "$SETTINGS_BACKUP" "$SETTINGS_FILE" 2>/dev/null || rm -f "$SETTINGS_BACKUP"
  fi
}
trap cleanup EXIT INT TERM HUP

# Cortex 1.0.73's --config flag does NOT override settings for the keys we
# care about (sqlConnectionName, cortexAgentConnectionName) in the TUI header
# — they're read straight from ~/.snowflake/cortex/settings.json. Patch the
# user's file in place and restore on exit so concurrent sessions don't
# clobber each other's persistent prefs.
patch_settings() {
  mkdir -p "$(dirname "$SETTINGS_FILE")"
  if [[ -f "$SETTINGS_FILE" ]]; then
    SETTINGS_BACKUP=$(mktemp -t cortex-ollama-settings.XXXXXX) || return 1
    cp "$SETTINGS_FILE" "$SETTINGS_BACKUP"
  else
    SETTINGS_BACKUP=$(mktemp -t cortex-ollama-settings.XXXXXX) || return 1
    : > "$SETTINGS_BACKUP"  # marker for "no original existed"
  fi
  CORTEX_AGENT_CONNECTION="$CORTEX_AGENT_CONNECTION" \
  CORTEX_SQL_CONNECTION="${CORTEX_SQL_CONNECTION:-}" \
  SETTINGS_FILE="$SETTINGS_FILE" \
  python3 - <<'PY'
import json, os, pathlib
p = pathlib.Path(os.environ["SETTINGS_FILE"])
data = {}
if p.exists():
    try: data = json.loads(p.read_text())
    except Exception: data = {}
data["cortexAgentConnectionName"] = os.environ["CORTEX_AGENT_CONNECTION"]
sql = os.environ.get("CORTEX_SQL_CONNECTION", "").strip()
if sql:
    data["sqlConnectionName"] = sql
elif "sqlConnectionName" in data:
    del data["sqlConnectionName"]
p.write_text(json.dumps(data, indent=2))
PY
}
patch_settings || { echo "cortex-ollama: failed to patch settings.json" >&2; exit 1; }

# Symlink the repo's slash commands into Cortex's global commands dir so
# /local-model and /local-models are discoverable inside the TUI. Idempotent.
install_slash_commands() {
  local src="$REPO_DIR/commands" dst="$HOME/.snowflake/cortex/commands"
  [[ -d "$src" ]] || return 0
  mkdir -p "$dst"
  for f in "$src"/*.md; do
    [[ -f "$f" ]] || continue
    local name target
    name=$(basename "$f")
    target="$dst/$name"
    if [[ ! -L "$target" ]] || [[ "$(readlink "$target")" != "$f" ]]; then
      ln -sf "$f" "$target"
    fi
  done
}
install_slash_commands

if healthz; then
  echo "cortex-ollama: proxy already running on :${PROXY_HTTP_PORT} — reusing it."
else
  if [[ -n "${OLLAMA_MODEL:-}" ]]; then
    echo "cortex-ollama: starting proxy with OLLAMA_MODEL=${OLLAMA_MODEL}..."
  else
    echo "cortex-ollama: starting proxy..."
  fi
  ( cd "$REPO_DIR" && exec pixi run serve >/tmp/cortex-ollama-proxy.log 2>&1 ) &
  PROXY_PID=$!

  for i in $(seq 1 30); do
    if healthz; then
      echo "cortex-ollama: proxy ready (pid $PROXY_PID, log /tmp/cortex-ollama-proxy.log)"
      break
    fi
    if ! kill -0 "$PROXY_PID" 2>/dev/null; then
      echo "cortex-ollama: proxy exited before becoming ready. See /tmp/cortex-ollama-proxy.log" >&2
      tail -30 /tmp/cortex-ollama-proxy.log >&2 || true
      exit 1
    fi
    sleep 1
  done
  if ! healthz; then
    echo "cortex-ollama: proxy did not become ready within 30s. See /tmp/cortex-ollama-proxy.log" >&2
    tail -30 /tmp/cortex-ollama-proxy.log >&2 || true
    exit 1
  fi
fi

ACTIVE_MODEL=$(curl -sS "http://127.0.0.1:${PROXY_HTTP_PORT}/healthz" \
  | python3 -c 'import sys,json; print(json.load(sys.stdin).get("model",""))' 2>/dev/null)

AVAILABLE_MODELS=$(curl -sS --max-time 2 "${OLLAMA_URL}/api/tags" 2>/dev/null \
  | python3 -c 'import sys,json
try: ms = json.load(sys.stdin).get("models", [])
except Exception: ms = []
print(", ".join(sorted(m["name"] for m in ms)))' 2>/dev/null || echo "")

ACTIVE_BACKEND=$(curl -sS --max-time 2 "http://127.0.0.1:${PROXY_HTTP_PORT}/healthz" 2>/dev/null \
  | python3 -c 'import sys,json
try: print(json.load(sys.stdin).get("backend",""))
except Exception: pass' 2>/dev/null || echo "")

if [[ -n "${CORTEX_SQL_CONNECTION:-}" ]]; then
  echo "cortex-ollama: hybrid mode — agent=${CORTEX_AGENT_CONNECTION}, sql=${CORTEX_SQL_CONNECTION}, backend=${ACTIVE_BACKEND}, model=${ACTIVE_MODEL}"
else
  echo "cortex-ollama: fully-local mode — backend=${ACTIVE_BACKEND}, model=${ACTIVE_MODEL}"
fi
if [[ "$ACTIVE_BACKEND" == "ollama" ]] && [[ -n "$AVAILABLE_MODELS" ]]; then
  echo "cortex-ollama: ollama has [${AVAILABLE_MODELS}] — set OLLAMA_MODEL to switch."
fi

# Pass the active local model through Cortex's -m flag so the TUI header
# shows the actual Ollama model instead of "auto". Cortex's model selection
# is otherwise a no-op for us — our proxy intercepts every agent turn and
# sends `_current_model` to Ollama regardless of what -m says.
MODEL_FLAG=()
if [[ -n "$ACTIVE_MODEL" ]]; then
  MODEL_FLAG=(-m "$ACTIVE_MODEL")
fi

# We can't `exec` here because we need the EXIT trap to restore settings.json.
"$CORTEX_BIN" -c "$CORTEX_AGENT_CONNECTION" "${MODEL_FLAG[@]}" --no-auto-update \
  ${PASSTHRU[@]+"${PASSTHRU[@]}"}
